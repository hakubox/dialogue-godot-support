# ============================================
# Node.js 依赖
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# TypeScript 编译输出
# ============================================
out/
dist/
build/
*.js
*.js.map
*.d.ts

# ⚠️ 但保留配置文件中的 .js
!webpack.config.js
!rollup.config.js
!jest.config.js
!.eslintrc.js

# ============================================
# VSCode 扩展特定
# ============================================
*.vsix                    # 打包后的扩展文件
.vscode-test/             # 测试运行时生成
.vscode-test-web/

# ============================================
# 编辑器和 IDE
# ============================================
.vscode/                  # VSCode 配置（可选，团队共享时保留）
.idea/                    # JetBrains IDE
*.swp                     # Vim
*.swo
*~

# ⚠️ 如果需要共享 VSCode 配置，改为：
# .vscode/*
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json
# !.vscode/extensions.json

# ============================================
# 操作系统文件
# ============================================
.DS_Store                 # macOS
Thumbs.db                 # Windows
Desktop.ini
$RECYCLE.BIN/

# ============================================
# 测试覆盖率
# ============================================
coverage/
.nyc_output/
*.lcov

# ============================================
# 环境变量和敏感信息
# ============================================
.env
.env.local
.env.*.local
secrets.json

# ============================================
# 日志文件
# ============================================
logs/
*.log
lerna-debug.log*

# ============================================
# 临时文件
# ============================================
tmp/
temp/
*.tmp
*.temp
.cache/

# ============================================
# 打包和发布
# ============================================
*.tgz
*.tar.gz

# ============================================
# TypeScript 缓存
# ============================================
*.tsbuildinfo
.tscache/

# ============================================
# ESLint 缓存
# ============================================
.eslintcache

# ============================================
# Prettier 缓存
# ============================================
.prettiercache

# ============================================
# 备份文件
# ============================================
*.bak
*.backup
*.old

# ============================================
# 项目特定（根据你的需求调整）
# ============================================
# 如果你有测试用的临时 .dialogue 文件
test-files/*.dialogue

# 如果你生成文档到 docs/
# docs/

# 如果你有生成的语法高亮文件
# syntaxes/*.json