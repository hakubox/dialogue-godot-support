{
  "name": "dialogue-godot-support",
  "displayName": "Godot Dialogue Manager 增强",
  "description": "为 Godot 4.x Dialogue Manager 提供强大的 VSCode 支持，包括完整的语法高亮、Godot 类/方法的智能补全、实时类型检查、定义跳转、参数提示、标签补全和 Import 路径补全等功能。",
  "publisher": "hakubox",
  "version": "0.3.1",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hakubox/dialogue-godot-support.git"
  },
  "homepage": "https://github.com/hakubox/dialogue-godot-support#readme",
  "bugs": {
    "url": "https://github.com/hakubox/dialogue-godot-support/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dialogue.exportJSON",
        "title": "Dialogue: 导出文案",
        "category": "Dialogue"
      },
      {
        "command": "dialogue.previewJSON",
        "title": "Dialogue: 预览文案 (JSON)",
        "category": "Dialogue"
      },
      {
        "command": "dialogue.copyJSON",
        "title": "Dialogue: 复制文案 (JSON)",
        "category": "Dialogue"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == dialogue",
          "command": "dialogue.exportJSON",
          "group": "dialogue@1"
        },
        {
          "when": "resourceLangId == dialogue",
          "command": "dialogue.previewJSON",
          "group": "dialogue@2"
        },
        {
          "when": "resourceLangId == dialogue",
          "command": "dialogue.copyJSON",
          "group": "dialogue@3"
        }
      ],
      "commandPalette": [
        {
          "command": "dialogue.exportJSON",
          "when": "resourceLangId == dialogue"
        },
        {
          "command": "dialogue.previewJSON",
          "when": "resourceLangId == dialogue"
        },
        {
          "command": "dialogue.copyJSON",
          "when": "resourceLangId == dialogue"
        }
      ]
    },
    "configuration": {
      "title": "Dialogue Godot Support",
      "properties": {
        "dialogue.diagnostics.globalClasses": {
          "type": "array",
          "default": [],
          "description": "全局类列表（可以在对话中省略类名前缀）",
          "items": {
            "type": "string"
          },
          "markdownDescription": "配置后可以在对话中直接使用成员名，无需类名前缀。\n\n例如：配置 `StageManager` 后，可以直接写 `{{count}}` 而不是 `{{StageManager.count}}`",
          "examples": [
            [
              "StageManager",
              "PlayerState",
              "AudioManager"
            ]
          ]
        },
        "dialogue.diagnostics.globalVariables": {
          "type": "object",
          "default": {},
          "description": "全局变量定义（支持复杂嵌套类型）",
          "patternProperties": {
            "^[a-zA-Z_][a-zA-Z0-9_]*$": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "变量类型（如 String、int、Dictionary、Array、自定义类名）"
                },
                "comment": {
                  "type": "string",
                  "description": "变量说明"
                },
                "schema": {
                  "type": "object",
                  "description": "复杂类型的内部结构（仅 Dictionary 可用）",
                  "patternProperties": {
                    "^[a-zA-Z_][a-zA-Z0-9_]*$": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "description": "字段类型（支持 ? 表示可选，如 String?）"
                        },
                        "comment": {
                          "type": "string"
                        },
                        "schema": {
                          "type": "object",
                          "description": "嵌套结构（支持无限层级）"
                        },
                        "itemType": {
                          "type": "string",
                          "description": "Array 的元素类型（仅 Array 可用）"
                        }
                      },
                      "required": [
                        "type"
                      ]
                    }
                  }
                },
                "itemType": {
                  "type": "string",
                  "description": "Array 的元素类型（仅 Array 可用）"
                }
              },
              "required": [
                "type"
              ]
            }
          },
          "markdownDescription": "配置全局变量，支持复杂嵌套类型：\n\n**示例 1：简单类型**\n```json\n{\n  \"playerName\": {\n    \"type\": \"String\",\n    \"comment\": \"玩家名\"\n  }\n}\n```\n\n**示例 2：Dictionary 嵌套**\n```json\n{\n  \"playerStats\": {\n    \"type\": \"Dictionary\",\n    \"comment\": \"玩家属性\",\n    \"schema\": {\n      \"hp\": { \"type\": \"int\", \"comment\": \"血量\" },\n      \"skills\": {\n        \"type\": \"Array\",\n        \"itemType\": \"String\",\n        \"comment\": \"技能列表\"\n      }\n    }\n  }\n}\n```\n\n**示例 3：可选类型**\n```json\n{\n  \"equipment\": {\n    \"type\": \"Dictionary\",\n    \"schema\": {\n      \"weapon\": { \"type\": \"String\" },\n      \"armor\": { \"type\": \"String?\", \"comment\": \"可选\" }\n    }\n  }\n}\n```"
        },
        "dialogue.diagnostics.strictMode": {
          "type": "boolean",
          "default": false,
          "description": "启用严格模式：对所有无法验证的调用报告警告"
        },
        "dialogue.diagnostics.builtInVariables": {
          "type": "object",
          "default": {
            "player": "CharacterBody2D",
            "game": "Game"
          },
          "description": "内置变量的类型映射"
        }
      }
    },
    "languages": [
      {
        "id": "dialogue",
        "aliases": [
          "Dialogue",
          "dialogue"
        ],
        "extensions": [
          ".dialogue"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "dialogue",
        "scopeName": "source.dialogue",
        "path": "./syntaxes/dialogue.tmLanguage.json"
      }
    ]
  },
  "keywords": [
    "godot",
    "dialogue",
    "game development",
    "gdscript",
    "dialogue manager",
    "dialogue_manager"
  ],
  "tags": [
    "godot",
    "game-dev",
    "dialogue"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "clean": "rm -rf out *.vsix",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:clean": "npm run clean && npm run compile && npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}